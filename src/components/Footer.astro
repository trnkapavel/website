---
import { Image } from 'astro:assets';
import home from '../content/singletons/home.json';
import settings from '../content/singletons/settings.json';
import photo from '../assets/about/pavel-trnka.jpg';
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <p class="label">Contact</p>
    <h2 class="display"><em>{home.ctaTitle}</em></h2>
    <div class="contact-row">
      <Image src={photo} alt="Pavel Trnka" width={320} height={320} class="avatar" />
      <a class="email" href={`mailto:${settings.email}`}>{settings.email}</a>
    </div>
    <div class="foot-row">
      <p class="socials">
        {settings.socials.map((s) => <a href={s.url}>{s.label}</a>)}
      </p>
      <p class="colophon">© {year} {settings.siteName}</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--ink);
    color: var(--paper);
    margin-top: 5rem;
    padding-block: 4.5rem 2rem;
  }
  .label { color: #b9b3a8; }
  h2 { margin-top: 1.25rem; max-width: 16ch; }
  .contact-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .avatar {
    display: block;
    width: 4.5rem;
    height: 4.5rem;
    flex-shrink: 0;
    border-radius: 50%;
    object-fit: cover;
  }
  .email {
    display: inline-block;
    font-family: var(--serif);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
  }
  .email:hover { opacity: 0.7; }
  .foot-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 4rem;
    padding-top: 1.25rem;
    border-top: 1px solid #3a3936;
  }
  .socials { display: flex; gap: 1.5rem; }
  .socials a {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .socials a:hover { text-decoration: underline; }
  .colophon { font-size: 0.6875rem; letter-spacing: 0.14em; text-transform: uppercase; color: #b9b3a8; }

  @media (prefers-reduced-motion: no-preference) {
    .email { transition: opacity 0.2s ease; }
  }
</style>

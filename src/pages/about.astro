---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import about from '../content/singletons/about.json';

const paragraphs = about.body.split(/\n\s*\n/).filter(Boolean);
const photo = (about as { photo?: string }).photo;
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/about/*', { eager: true });
const photoEntry = photo ? images[`../assets/about/${photo.replace(/^.*\//, '')}`] : undefined;
---
<BaseLayout title={about.title} description="Who I am — senior brand & product designer working with AI.">
  <section class="wrap">
    <header><h1>{about.title}</h1></header>
    {photoEntry && <Image src={photoEntry.default} alt="Portrait of Pavel Trnka" widths={[480, 960]} sizes="(max-width: 40rem) 100vw, 30rem" format="webp" class="photo" />}
    <div class="prose">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </section>
</BaseLayout>

<style>
  header { padding-block: 3.5rem 2rem; }
  .prose { padding-bottom: 2rem; }
  .photo { max-width: 30rem; margin-bottom: 2rem; }
</style>

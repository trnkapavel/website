---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionRail from '../components/SectionRail.astro';
import home from '../content/singletons/home.json';
import settings from '../content/singletons/settings.json';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order).slice(0, 2);
const posts = (await getCollection('writing'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const [emBefore, emAfter] = home.heroTitleEm.split('10×');
---
<BaseLayout>
  <SectionRail />
  <section class="wrap hero" id="hello" data-spy="01">
    <svg class="hero-lines" viewBox="0 0 420 600" aria-hidden="true">
      <path class="line line-1" d="M 20,560 C 120,520 130,380 240,340 C 340,305 360,180 400,40" />
      <path class="line line-2" d="M 60,600 C 160,570 170,430 280,400 C 370,375 380,240 340,120" />
      <path class="line line-3" d="M 0,420 C 110,400 140,260 250,220 C 330,192 320,90 260,10" />
    </svg>
    <p class="label"><span aria-hidden="true">①</span> Hello</p>
    <h1 class="display">{home.heroTitle}<br /><em>{emBefore}<span class="metric">10×</span>{emAfter}</em></h1>
    <div class="hero-foot">
      <p class="sub">{home.heroSubtitle}</p>
      <div class="hero-ctas">
        <a class="cta" href="/how-i-work/">See how I work <span aria-hidden="true">↓</span></a>
        <a class="cta-quiet" href={`mailto:${settings.email}`}>Or email me directly <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="wrap block" id="process" data-spy="02">
    <h2 class="label"><span aria-hidden="true">②</span> Process</h2>
    <div class="steps">
      {home.steps.map((step, i) => (
        <div class="step" data-num={String(i + 1).padStart(2, '0')} data-reveal style={`transition-delay:${i * 80}ms`}>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-desc">{step.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="wrap block" data-chapter="03" id="work" data-spy="03">
    <h2 class="label"><span aria-hidden="true">③</span> Selected work</h2>
    <div class="work-list">
      {work.map((cs, i) => (
        <a class="work-card" href={`/work/${cs.id}/`} data-reveal style={`transition-delay:${i * 100}ms`}>
          <div class="frame">
            <Image
              src={cs.data.cover}
              alt=""
              widths={[768, 1200, 2400]}
              sizes="(max-width: 72rem) 100vw, 72rem"
              format="webp"
            />
          </div>
          <div class="work-meta">
            <h3>{cs.data.title} <span class="arrow" aria-hidden="true">→</span></h3>
            <p class="label">{cs.data.category} · {cs.data.year}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="wrap block columns">
    <div data-chapter="04" id="writing" data-spy="04">
      <h2 class="label"><span aria-hidden="true">④</span> Writing</h2>
      <ul class="post-list">
        {posts.map((post, i) => (
          <li data-reveal style={`transition-delay:${i * 80}ms`}><a href={`/writing/${post.id}/`}>{post.data.title}<span class="arrow" aria-hidden="true"> →</span></a></li>
        ))}
      </ul>
      <p class="all-link"><a href="/writing/">All writing</a></p>
    </div>
    <div data-chapter="05" id="services" data-spy="05">
      <h2 class="label"><span aria-hidden="true">⑤</span> Services</h2>
      <ul class="service-list">
        {home.services.map((service, i) => (
          <li data-reveal style={`transition-delay:${i * 80}ms`}><span class="idx" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>{service}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { position: relative; padding-block: 5.5rem 4rem; border-bottom: 1px solid var(--line-soft); }
  .hero h1 { margin-top: 1.5rem; text-wrap: balance; }
  .hero h1 em { color: var(--muted); }
  .hero .metric {
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    display: inline-block;
    min-width: 2ch;
  }
  .hero > .label, .hero > h1, .hero > .hero-foot { position: relative; z-index: 1; }

  /* Hero line drawing — a pen-drawn abstract mark instead of a generic AI gradient blob */
  .hero-lines {
    position: absolute;
    top: 0;
    right: 0;
    width: min(30vw, 22rem);
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: visible;
  }
  .hero-lines .line { fill: none; stroke-linecap: round; }
  .hero-lines .line-1 { stroke: var(--accent); stroke-width: 1.5; }
  .hero-lines .line-2 { stroke: var(--line-soft); stroke-width: 1.25; }
  .hero-lines .line-3 { stroke: var(--faint); stroke-width: 1; }

  @media (prefers-reduced-motion: no-preference) {
    .hero-lines .line {
      stroke-dasharray: 1000;
      stroke-dashoffset: 1000;
      animation: draw-line 7s ease-in-out infinite;
    }
    .hero-lines .line-2 { animation-delay: 0.15s; }
    .hero-lines .line-3 { animation-delay: 0.3s; }
  }
  @keyframes draw-line {
    0%, 8% { stroke-dashoffset: 1000; }
    45%, 55% { stroke-dashoffset: 0; }
    92%, 100% { stroke-dashoffset: -1000; }
  }

  @media (max-width: 48rem) {
    .hero-lines { display: none; }
  }
  .hero-foot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .sub { max-width: 34rem; color: var(--muted); font-size: 1.0625rem; }
  .cta {
    flex-shrink: 0;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 3px;
    white-space: nowrap;
  }
  .cta:hover { opacity: 0.6; }

  .hero-ctas { display: flex; flex-direction: column; align-items: flex-end; gap: 0.75rem; flex-shrink: 0; }
  .cta-quiet {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--muted);
    white-space: nowrap;
  }
  .cta-quiet:hover { color: var(--ink); }

  .block { padding-block: 4rem; border-bottom: 1px solid var(--line-soft); }

  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 2rem; }
  .step { border-top: 1px solid var(--line); padding-top: 1.25rem; }
  .step::before {
    content: attr(data-num);
    display: block;
    font-family: var(--serif);
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    line-height: 1;
    color: var(--paper);
    -webkit-text-stroke: 1px var(--faint);
    margin-bottom: 1rem;
  }
  .step-title { font-family: var(--sans); font-size: 1rem; font-weight: 700; }
  .step-desc { margin-top: 0.5rem; font-size: 0.9375rem; color: var(--muted); max-width: 26ch; }

  .work-list { display: grid; gap: 3.5rem; margin-top: 2rem; }
  .work-card { text-decoration: none; display: block; }
  .frame { overflow: hidden; border: 1px solid var(--line-soft); }
  .frame img { width: 100%; aspect-ratio: 16 / 8; object-fit: cover; }
  .work-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }
  .work-card h3 { font-size: clamp(1.625rem, 3.2vw, 2.375rem); }
  .work-card .arrow { display: inline-block; }
  .work-card:hover h3 { text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 6px; }

  .columns { display: grid; grid-template-columns: 3fr 2fr; gap: 4rem; }
  .post-list { list-style: none; padding: 0; margin-top: 1.5rem; }
  .post-list li { border-bottom: 1px solid var(--line-soft); }
  .post-list li:last-child { border-bottom: 0; }
  .post-list a {
    display: block;
    padding-block: 0.875rem;
    font-family: var(--serif);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    text-decoration: none;
  }
  .post-list .arrow { opacity: 0; }
  .post-list a:hover { text-decoration: underline; text-underline-offset: 4px; }
  .post-list a:hover .arrow { opacity: 1; }
  .all-link { margin-top: 1.25rem; }
  .all-link a {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 2px;
  }
  .service-list { list-style: none; padding: 0; margin-top: 1.5rem; }
  .service-list li {
    padding-block: 0.75rem;
    border-bottom: 1px solid var(--line-soft);
    font-size: 0.9375rem;
  }
  .service-list li:last-child { border-bottom: 0; }
  .service-list .idx {
    font-family: var(--serif);
    font-style: italic;
    color: var(--faint);
    margin-right: 0.875rem;
  }

  /* Folio watermark — echoes .step::before to give the thinner sections more editorial weight */
  [data-chapter] { position: relative; }
  [data-chapter]::before {
    content: attr(data-chapter);
    position: absolute;
    top: 0;
    right: 0;
    font-family: var(--serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1;
    color: var(--paper);
    -webkit-text-stroke: 1px var(--line-soft);
    pointer-events: none;
    z-index: 0;
  }
  [data-chapter] > * { position: relative; z-index: 1; }

  @media (prefers-reduced-motion: no-preference) {
    .frame img { transition: transform 0.6s ease; }
    .work-card:hover .frame img { transform: scale(1.025); }
    .post-list .arrow { transition: opacity 0.2s ease; }
    .cta { transition: opacity 0.2s ease; }
  }

  @media (max-width: 48rem) {
    .hero-foot { flex-direction: column; align-items: flex-start; }
    .hero-ctas { align-items: flex-start; margin-top: 0.5rem; }
    .steps, .columns { grid-template-columns: 1fr; }
    .columns { gap: 3rem; }
  }
</style>

<script>
  const metric = document.querySelector<HTMLElement>('.hero .metric');
  if (metric && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const target = 10;
    const duration = 900;
    const start = performance.now();
    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      metric.textContent = `${Math.round(progress * target)}×`;
      if (progress < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>
